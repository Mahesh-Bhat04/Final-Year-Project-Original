# Azure Storage Configuration (FILL IN YOUR VALUES)
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name_here
AZURE_STORAGE_ACCOUNT_KEY=your_account_key_here
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
AZURE_CONTAINER_NAME=encrypted-files

# Merkle Tree Configuration
MERKLE_CHUNK_SIZE=262144
MERKLE_HASH_ALGORITHM=sha256

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
